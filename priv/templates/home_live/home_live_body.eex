use <%= @web_module %>, :live_view

@impl true
def page_meta(_socket, :home),
  do: %PageMeta{
    title: "Welcome",
    path: "/"
  }

@impl true
def render(assigns) do
  ~H"""
  <h1>Welcome</h1>
  """
end

@impl true
def mount(_params, _session, socket) do
  {:ok, socket |> assign_page_meta()}
end
